# ── Docker / Ports ──────────────────────────────────────────
POSTGRES_USER=sazon
POSTGRES_PASSWORD=sazon_password
POSTGRES_DB=sazon_db
POSTGRES_PORT=5432
BACKEND_PORT=8000
STREAMLIT_PORT=8501

# ── LLM Backend ─────────────────────────────────────────────
# Switch: ollama | openai
LLM_BACKEND=ollama

# ── Ollama — multi-GPU ─────────────────────────────────────
# Path to the ollama binary on the host (only needed for --ollama mode)
OLLAMA_BIN=/usr/local/bin/ollama
# Base address Docker containers use to reach the host
OLLAMA_HOST=host.docker.internal

# GPU 0 — fat reasoning model
OLLAMA_GPU0_PORT=11434
OLLAMA_GPU0_MODEL=qwen2.5:27b
OLLAMA_GPU0_VISIBLE_DEVICES=0

# GPU 1 — smaller models (chat + judge)
OLLAMA_GPU1_PORT=11435
OLLAMA_GPU1_MODELS=llama3:8b,mistral
OLLAMA_GPU1_VISIBLE_DEVICES=1

# To add more GPUs: OLLAMA_GPU2_PORT=..., OLLAMA_GPU2_MODELS=..., OLLAMA_GPU2_VISIBLE_DEVICES=2

# ── OpenAI (fallback when LLM_BACKEND=openai) ──────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
